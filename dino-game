<!DOCTYPE html>
<html>
<head>
  <title>Dino Game</title>
  <style>
    body { margin: 0; background: #f4f4f4; text-align: center; }
    canvas { background: white; margin-top: 50px; border: 2px solid black; }
  </style>
</head>
<body>
  <h2>Press SPACE to Jump</h2>
  <canvas id="game" width="600" height="200"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let dino = { x: 50, y: 150, vy: 0, jump: false };
let gravity = 0.6;
let obstacle = { x: 600, y: 160, w: 20, h: 40 };

document.addEventListener("keydown", e => {
  if (e.code === "Space" && !dino.jump) {
    dino.vy = -10;
    dino.jump = true;
  }
});

function update() {
  dino.y += dino.vy;
  dino.vy += gravity;

  if (dino.y >= 150) {
    dino.y = 150;
    dino.jump = false;
  }

  obstacle.x -= 5;
  if (obstacle.x < -20) obstacle.x = 600;

  if (
    dino.x < obstacle.x + obstacle.w &&
    dino.x + 20 > obstacle.x &&
    dino.y < obstacle.y + obstacle.h &&
    dino.y + 20 > obstacle.y
  ) {
    alert("Game Over!");
    obstacle.x = 600;
  }
}

function draw() {
  ctx.clearRect(0,0,600,200);

  ctx.fillStyle = "black";
  ctx.fillRect(dino.x, dino.y, 20, 20);

  ctx.fillStyle = "red";
  ctx.fillRect(obstacle.x, obstacle.y, obstacle.w, obstacle.h);
}

function loop() {
  update();
  draw();
  requestAnimationFrame(loop);
}

loop();
</script>
</body>
</html>
